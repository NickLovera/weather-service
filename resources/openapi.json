{
  "openapi": "3.0.3",
  "info": {
    "title": "Weather Service API",
    "version": "1.0.0",
    "description": "A basic API for retrieving weather forecast information."
  },
  "security": [],
  "components": {
    "securitySchemes": {  }
  },
  "paths": {
    "/currentweather/{lat}/{long}": {
      "get": {
        "summary": "Get today's weather summary",
        "parameters": [
          {
            "name": "lat",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number",
              "format": "float"
            },
            "description": "Latitude coordinate"
          },
          {
            "name": "long",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number",
              "format": "float"
            },
            "description": "Longitude coordinate"
          }
        ],
        "responses": {
          "200": {
            "description": "Weather information for the supplied coordinates",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "city": {
                      "type": "string"
                    },
                    "state": {
                      "type": "string"
                    },
                    "forecast": {
                      "type": "string"
                    },
                    "tempCharacteristic": {
                      "type": "string",
                      "enum": ["Hot", "Cold", "Moderate"]
                    }
                  }
                },
                "example": {
                  "city": "Boyd",
                  "state": "TX",
                  "forecast": "Partly Cloudy",
                  "tempCharacteristic": "Hot"
                }
              }
            }
          }
        }
      }
    }
  }
}
